<div class="hero"
     style="background-image: url('https://images.unsplash.com/photo-1489599849927-2ee91cede3ba?w=1600&q=80');">
  <div class="hero-inner">
    <h1>Save any kind of movies</h1>
    <span class="hero-tag">Your personal cinema</span>
  </div>
</div>

<div class="container my-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="section-heading mb-0">My Lists</h1>
    <%= link_to "＋ Create a movie list", new_list_path, class: "btn btn-mint" %>
  </div>

  <% if @lists.any? %>
    <div class="cards">
      <% @lists.each do |list| %>
        <div class="list-card">
          <%= link_to list_path(list), class: "list-card-link" do %>
            <div class="list-card-cover"
                 style="background-image: url(<%= list.photo.attached? ? cl_image_path(list.photo.key) : 'https://happiclap.com/wp-content/uploads/2019/06/Everyday-Clapboard-1.jpg' %>)">
              <span class="list-card-title"><%= list.name %></span>
            </div>
          <% end %>
          <%= button_to list_path(list), method: :delete,
                class: "list-card-delete",
                data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } do %>
            <i class="fa-solid fa-trash"></i>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <p class="mb-3">No lists yet — your marquee is empty.</p>
      <%= link_to "Create your first list", new_list_path, class: "btn btn-mint" %>
    </div>
  <% end %>
</div>
