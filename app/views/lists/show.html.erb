<%= link_to "← Back to lists", lists_path, class: "btn btn-link ps-4 mt-3" %>

<%# Hero reusing uploaded image as backdrop %>
<div class="list-hero"
     style="background-image: url(<%= @list.photo.attached? ? cl_image_path(@list.photo.key) : 'https://happiclap.com/wp-content/uploads/2019/06/Everyday-Clapboard-1.jpg' %>)">
  <span class="movie-badge"><%= pluralize(@list.bookmarks.count, "movie") %></span>
  <h1><%= @list.name %></h1>
</div>

<div class="container my-4">
  <%# "add a movie" button that expands the form %>
  <details class="add-movie">
    <summary class="btn btn-mint">＋ add a movie</summary>
    <div class="mt-3">
      <%= render "bookmarks/form", list: @list, bookmark: @bookmark %>
    </div>
  </details>

  <% if @list.bookmarks.any? %>
    <div class="movie-grid mt-4 mb-5">
      <% @list.bookmarks.each do |bookmark| %>
        <div class="movie-card">
          <div class="movie-poster"
               style="background-image: url('<%= bookmark.movie.poster_url %>')"></div>
          <div class="movie-body">
            <h5 class="movie-title">
              <%= bookmark.movie.title %>
              <% if bookmark.movie.respond_to?(:rating) && bookmark.movie.rating.present? %>
                <span class="movie-rating">&middot; <%= bookmark.movie.rating %>
                  <i class="fa-solid fa-star"></i>
                </span>
              <% end %>
            </h5>

            <% if bookmark.movie.respond_to?(:overview) && bookmark.movie.overview.present? %>
              <p class="movie-overview"><%= bookmark.movie.overview %></p>
            <% end %>

            <div class="movie-footer">
              <span class="movie-comment">
                <i class="fa-solid fa-quote-left"></i>
                <%= bookmark.comment %>
              </span>
              <%= button_to "delete", bookmark_path(bookmark), method: :delete,
                    class: "movie-delete",
                    data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state mb-5">
      No movies in this list yet — add one above.
    </div>
  <% end %>
</div>
