<h1><%= @list.name %></h1>
<%= link_to "Add a movie", new_list_bookmark_path(@list), class: "btn btn-primary" %>

<div class="row">
  <% @list.bookmarks.each do |bookmark| %>
    <div class="col-md-4 card">
      <%= image_tag bookmark.movie.poster_url, class: "card-img-top" %>
      <div class="card-body">
        <h5><%= bookmark.movie.title %></h5>
        <p><%= bookmark.comment %></p>
        <%= button_to "Remove", bookmark_path(bookmark), method: :delete, class: "btn btn-danger", data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %>
      </div>
    </div>
  <% end %>
</div>
